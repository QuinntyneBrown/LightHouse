@startuml seq-upload-content
title Upload Content Workflow

actor Admin as A
participant "Admin Dashboard" as UI
participant "ContentController" as Ctrl
participant "UploadService" as Upload
participant "ContentService" as Content
participant "IndexingService" as Index
database "MinIO" as S3
database "PostgreSQL" as DB
participant "Meilisearch" as MS

A -> UI : Fill metadata form\n(title, type, category, tags)
UI -> Ctrl : POST /content\n{ title, type, ... }
Ctrl -> Content : createContent(data)
Content -> DB : INSERT Content\n(status=DRAFT)
Content --> Ctrl : contentId
Ctrl --> UI : 201 { contentId }

A -> UI : Select file to upload
UI -> Ctrl : POST /content/:id/upload-url\n{ fileType, fileSize }
Ctrl -> Upload : generatePresignedUrl(...)
Upload -> S3 : createPresignedPut()\n(30 min TTL, 2 GB max)
Upload --> Ctrl : presignedUrl
Ctrl --> UI : { uploadUrl }

UI -> S3 : PUT file directly\nto presigned URL
S3 --> UI : 200 OK

UI -> Ctrl : POST /content/:id/confirm-upload
Ctrl -> Upload : confirmUpload(contentId)
Upload -> S3 : headObject (verify exists)
Upload -> DB : UPDATE Content\n(streamUrl, status=DRAFT)
Upload --> Ctrl : confirmed

Ctrl -> Content : submitForReview(contentId)
Content -> DB : UPDATE status=PENDING_REVIEW
Content --> Ctrl : updated

@enduml
